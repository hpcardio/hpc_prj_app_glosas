# Copie para .env e ajuste antes de subir em producao.

FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=4007
PORT=8000

DJANGO_SECRET_KEY=troque-por-um-valor-longo-aleatorio
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,glosas.seudominio.com.br
DJANGO_CSRF_TRUSTED_ORIGINS=https://glosas.seudominio.com.br
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SECURE_PROXY_SSL_HEADER=1
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0

SESSION_COOKIE_AGE=28800
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SQLITE_PATH=/data/frontend.sqlite3
RUN_MIGRATIONS=1

API_BASE_URL=https://apihpc.hospitalprontocardio.com.br
API_CONTA_ATENDIMENTO_PATH=/app_glosas/
API_REGISTRO_GLOSA_PATH=/app_glosas/glosas
API_TISS_PATH=/app_glosas/tiss
API_TIMEOUT=15
API_BEARER_TOKEN=
DASHBOARD_CACHE_SECONDS=45
APP_FILTER_CACHE_SECONDS=45

SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=465
SMTP_USER=usuario@seudominio.com.br
SMTP_PASSWORD=senha_do_email
SMTP_FROM="Sistema de Glosas <usuario@seudominio.com.br>"
SMTP_USE_SSL=true
SMTP_USE_TLS=false

GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
